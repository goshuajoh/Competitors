# LLM API Keys — set at least one
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Auth — if set, users must enter this password to access the app
# If unset, no login required (good for local dev)
APP_PASSWORD=

# Session secret — random string for signing session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Server config
PORT=3001
NODE_ENV=production

# Set to "true" if behind a reverse proxy (Railway, Render, etc.)
TRUST_PROXY=true
